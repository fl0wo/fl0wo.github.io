---
import type { GetStaticPaths } from 'astro'
import Layout from '~/layouts/Layout.astro'
import { SeriesGroup } from '~/content-utils'
import PageHeader from '~/components/PageHeader.astro'
import PostPreview from '~/components/PostPreview.astro'
import { assertLang, supportedLangs, ui } from '~/i18n'

export const getStaticPaths = (async () => {
  const paths = []
  for (const lang of supportedLangs) {
    const seriesGroup = await SeriesGroup.build(lang)
    paths.push(
      ...seriesGroup.collations.map((series) => ({
        params: { lang, slug: series.titleSlug },
        props: { lang, posts: series.entries, seriesTitle: series.title },
      })),
    )
  }
  return paths
}) satisfies GetStaticPaths

const lang = assertLang(Astro.params.lang!)
const t = ui[lang]
const { posts, seriesTitle } = Astro.props
---

<Layout
  lang={lang}
  route={{ type: 'series', slug: Astro.params.slug! }}
  title={`Series: ${seriesTitle}`}
  description={`All posts in the ${seriesTitle} series`}
>
  <div class="mt-2 sm:mt-0">
    <PageHeader titlePieces={[t.series, seriesTitle]} />
    {posts.map((post) => <PostPreview post={post} lang={lang} />)}
  </div>
</Layout>
